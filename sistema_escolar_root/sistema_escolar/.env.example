# Configuracoes do App
APP_NAME="Sistema Escolar"
APP_ENV=production
BASE_URL=http://localhost/sistema_escolar

# Banco de dados
DB_PATH=C:/caminho/para/sistema_escolar/database/secretaria.db

# Pastas
UPLOAD_PATH=public/uploads/certidoes/
BACKUP_PATH=database/backups/
CLOUD_BACKUP_PATH=C:/caminho/para/backups/

# Email (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=seu-email@exemplo.com
MAIL_PASSWORD=sua-senha-ou-app-password
MAIL_FROM=seu-email@exemplo.com
MAIL_FROM_NAME="Secretaria Escolar"

# Alertas dos cron
ALERTA_DVA_DIAS=15
ALERTA_CERTIDAO_DIAS=15

# Opcional em ambiente controlado
MAIL_ALLOW_SELF_SIGNED=false
